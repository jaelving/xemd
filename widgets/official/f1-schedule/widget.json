      "https://api.jolpi.ca/**",
      "https://api.openf1.org/**",
      "https://files-f1.motorsportcalendars.com/**"
    ],
    "secrets": []
  },
  "settings": [
    { "key": "racesToShow", "label": "Upcoming races to show (Calendar tab)", "type": "number", "default": 5, "min": 3, "max": 8 }
  ]
}
