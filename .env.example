# XEMD environment variables
# Copy this file to .env and fill in values before running docker compose

# Master key for encrypting secrets at rest.
# Generate a strong random value: openssl rand -hex 32
XEMD_MASTER_KEY=change-me-before-going-to-production

# Admin token for protecting admin API endpoints (settings, secrets, widget state).
# Generate a strong random value: openssl rand -hex 32
XEMD_ADMIN_TOKEN=change-me-before-going-to-production

# Allowed origin for cross-origin API requests.
# In production behind nginx, the API is only reached via same-origin proxied requests
# so this can usually be left unset. Set it explicitly if you expose the API directly
# (e.g. http://your-host:6600 or https://xemd.example.com).
# XEMD_ALLOWED_ORIGIN=https://xemd.example.com

# Port the dashboard (kiosk + admin) is exposed on the host machine.
# Change this if 6600 conflicts with another service on your system.
# Default: 6600
XEMD_HOST_PORT=6600

# Port the API is exposed on the host machine.
# The API is only used internally by the host container in production,
# so you can leave this as-is unless you need direct API access.
# Default: 3001
XEMD_API_PORT=3001

# ── Default widget API keys (optional) ──────────────────────
# If set, these are seeded into the encrypted secrets store on first startup.
# Any key saved via the Admin Panel will take precedence and will not be
# overwritten — these only apply if no key has been saved yet.

# Live Radar — FlightAware AeroAPI key (optional — adds origin/dest to traffic list)
# The radar works without this key; airplanes.live is free and needs no auth.
# Sign up at: https://www.flightaware.com/commercial/aeroapi/
# XEMD_FLIGHTAWARE_KEY=your_flightaware_key_here

# Stock Tracker — Finnhub API key
# Sign up free at: https://finnhub.io/
# XEMD_STOCK_TRACKER_API_KEY=your_finnhub_key_here
